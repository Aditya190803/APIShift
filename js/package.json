{
  "name": "@apishift/core",
  "version": "0.1.0",
  "description": "Core TypeScript library for APIShift",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "lint": "tsc"
  },
  "dependencies": {
    "ai": "^4.1.12",
    "@ai-sdk/google": "^1.1.2",
    "@ai-sdk/openai": "^1.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsup": "^8.3.5",
    "@types/node": "^22.10.7"
  }
}
